  "name": "assetflow",
  "dockerComposeFile": "../docker-compose.yml",
  "service": "api",
  "workspaceFolder": "/workspaces/assetflow",
  "forwardPorts": [
    80,
    5174,
    5432
  ],
  "postCreateCommand": "echo 'Assetflow ready'",
  "features": {
    "ghcr.io/devcontainers/features/docker-outside-of-docker": {
      "moby": false
    }
  }
}